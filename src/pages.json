{
  "globalStyle": {
    "navigationBarBackgroundColor": "@navBgColor",
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "Oiyo Starter",
    "backgroundColor": "@bgColor",
    "backgroundTextStyle": "@bgTxtStyle",
    "backgroundColorTop": "@bgColorTop",
    "backgroundColorBottom": "@bgColorBottom",
    "enablePullDownRefresh": false,
    "onReachBottomDistance": 50,
    "animationType": "pop-in",
    "animationDuration": 300
  },
  "tabBar": {
    "custom": true,
    "height": "0",
    "color": "@tabColor",
    "selectedColor": "@tabSelectedColor",
    "backgroundColor": "@tabBgColor",
    "borderStyle": "@tabBorderStyle",
    "list": [
      {
        "pagePath": "pages/home/index",
        "index": 0
      },
      {
        "pagePath": "pages/about/index",
        "index": 1
      }
    ]
  },
  "pages": [
    {
      "path": "pages/home/index",
      "type": "home",
      "name": "home",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "首页"
      },
      "tab": {
        "index": 0
      }
    },
    {
      "path": "pages/about/index",
      "name": "about",
      "layout": "tabbar",
      "style": {
        "navigationBarTitleText": "关于"
      },
      "tab": {
        "index": 1
      }
    }
  ],
  "subPackages": [
    {
      "root": "packages/async-echarts",
      "pages": [
        {
          "path": "index",
          "name": "echartsAsync",
          "style": {
            "navigationBarTitleText": "echarts 异步跨包示例"
          }
        }
      ]
    },
    {
      "root": "packages/echarts",
      "pages": [
        {
          "path": "index",
          "name": "echarts",
          "style": {
            "navigationBarTitleText": "Echarts 演示"
          }
        }
      ]
    },
    {
      "root": "packages/features",
      "pages": [
        {
          "path": "ci/index",
          "name": "ci",
          "style": {
            "navigationBarTitleText": "CI 持续集成"
          }
        },
        {
          "path": "feedback/index",
          "name": "feedback",
          "style": {
            "navigationBarTitleText": "全局反馈"
          }
        },
        {
          "path": "icon/index",
          "name": "icon",
          "style": {
            "navigationBarTitleText": "图标演示"
          }
        },
        {
          "path": "pinia/index",
          "name": "pinia",
          "style": {
            "navigationBarTitleText": "Pinia 演示"
          }
        },
        {
          "path": "router/demo-aftereach",
          "name": "demo-aftereach",
          "style": {
            "navigationBarTitleText": "afterEach 钩子演示"
          }
        },
        {
          "path": "router/demo-guard",
          "name": "demo-guard",
          "style": {
            "navigationBarTitleText": "导航守卫演示"
          }
        },
        {
          "path": "router/demo-object",
          "name": "demo-object",
          "style": {
            "navigationBarTitleText": "对象路径跳转"
          }
        },
        {
          "path": "router/demo-params",
          "name": "demo-params",
          "style": {
            "navigationBarTitleText": "参数接收演示"
          }
        },
        {
          "path": "router/demo-protected",
          "name": "demo-protected",
          "style": {
            "navigationBarTitleText": "受保护页面"
          }
        },
        {
          "path": "router/demo-query",
          "name": "demo-query",
          "style": {
            "navigationBarTitleText": "查询参数接收演示"
          }
        },
        {
          "path": "router/demo-string",
          "name": "demo-string",
          "style": {
            "navigationBarTitleText": "字符串路径跳转"
          }
        },
        {
          "path": "router/index",
          "name": "router",
          "style": {
            "navigationBarTitleText": "路由管理"
          }
        },
        {
          "path": "skills/index",
          "name": "skills",
          "layout": "default",
          "style": {
            "navigationBarTitleText": "Agent Skills",
            "navigationBarBackgroundColor": "#f9fafb",
            "navigationBarTextStyle": "black"
          }
        },
        {
          "path": "styles/index",
          "name": "styles",
          "style": {
            "navigationBarTitleText": "UnoCSS 演示"
          }
        }
      ]
    }
  ]
}
